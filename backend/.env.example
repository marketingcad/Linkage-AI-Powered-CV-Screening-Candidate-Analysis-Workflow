# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
NODE_ENV=development
PORT=4000
# Comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:5173

# ---------------------------------------------------------------------------
# Supabase Postgres
# Supabase Dashboard -> Project Settings -> Database -> Connection string ->
# "Connection pooling" (Transaction mode). Replace [YOUR-PASSWORD].
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres.flqwhncaakqfqmywrfku:[YOUR-PASSWORD]@aws-1-us-west-2.pooler.supabase.com:5432/postgres

# ---------------------------------------------------------------------------
# Auth
# ---------------------------------------------------------------------------
JWT_SECRET=GeRVY5LXrZ_rJHTylaq1n3Hujx16Xj5STbN8yKMej6bxZZDE8snQF1ePE_IPzBsREjHAPtb1uzRWCFp8EmeptQ
JWT_EXPIRES_IN=7d

# ---------------------------------------------------------------------------
# Google Gemini
# Get a key at https://aistudio.google.com/app/apikey
# ---------------------------------------------------------------------------
GEMINI_API_KEY_CV_SCREENING=example-key-for-cv-screening
GEMINI_MODEL=gemini-2.5-flash

# ---------------------------------------------------------------------------
# Uploads
# ---------------------------------------------------------------------------
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=10

# GDPR retention: auto-anonymize candidate PII older than N days (0 = disabled)
DATA_RETENTION_DAYS=0

# ---------------------------------------------------------------------------
# Email notifications (SMTP)
# Leave SMTP_HOST blank to log emails to the console instead of sending them.
# Works with Gmail (app password), SendGrid, Resend, Postmark, Mailtrap, etc.
# ---------------------------------------------------------------------------
APP_PUBLIC_URL=http://localhost:5173
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=ScreenAI Careers <no-reply@screenai.local>

# ---------------------------------------------------------------------------
# Seed script (npm run seed) — first HR/recruiter login
# ---------------------------------------------------------------------------
SEED_HR_EMAIL=hr@example.com
SEED_HR_PASSWORD=ChangeMe123!
SEED_HR_NAME=HR Admin
